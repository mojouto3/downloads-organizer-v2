{
  "name": "downloads-organizer-v2",
  "version": "2.0.0",
  "description": "A modern GUI tool to organize your Downloads folder",
  "main": "main.js",
  "author": "mojo",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.mojo.downloads-organizer",
    "productName": "Downloads Organizer",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Downloads Organizer"
    }
  }
}
